{
  "name": "octane-qa-task",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:firefox": "cypress run --browser firefox",
    "cy:run:mobile": "cypress run --config viewportWidth=375,viewportHeight=812",
    "cy:run:all": "npm run cy:run:chrome && npm run cy:run:firefox && npm run cy:run:mobile",
    "report:merge": "mochawesome-merge reports/*.json > reports/merged-report.json",
    "report:generate": "marge reports/merged-report.json --reportDir reports --reportFilename final-report --inline",
    "test:full": "npm run cy:run:all && npm run report:merge && npm run report:generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "cypress": "^15.11.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
